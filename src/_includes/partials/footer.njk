{# Renders the two-up footer. Expects a `footer` object with `left` and `right`,
   each { href, label, id }. Falls back to Work / Contact if not provided. #}
{% set f = footer or {
    left:  { href: "index.html#work", label: "Work",    id: "more-work" },
    right: { href: "contact.html",    label: "Contact", id: "about" }
} %}
<section id="footer" class="grid grid-cols-6 gap-4 m-4">
    <a href="{{ f.left.href }}" class="block col-span-6 md:col-span-3">
        <section id="{{ f.left.id }}" class="flex items-center justify-center roundy h-auto">
            <h2 class="text-4xl">{{ f.left.label }}</h2>
        </section>
    </a>
    <a href="{{ f.right.href }}" class="block col-span-6 md:col-span-3">
        <section id="{{ f.right.id }}" class="flex items-center justify-center roundy">
            <h2 class="text-4xl">{{ f.right.label }}</h2>
        </section>
    </a>
</section>
