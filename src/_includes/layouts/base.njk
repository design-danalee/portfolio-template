<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍕</text></svg>">
    <title>{{ title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@1&family=Schibsted+Grotesk&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="main.css">
    <link rel="stylesheet" href="size-small.css">
    <link rel="stylesheet" href="size-large.css">
    {% for href in pageStyles %}<link rel="stylesheet" href="{{ href }}">
    {% endfor %}
</head>
<body class="bg-white text-gray-900">
    <main>
        {% include "partials/header.njk" %}
{{ content | safe }}
        {% include "partials/footer.njk" %}
    </main>

    <script src="dotcursor.js"></script>
    <script src="random-colors.js"></script>
    <script src="favicon.js"></script>
    <script src="header.js?v=2"></script>
    {% for src in pageScripts %}<script src="{{ src }}"></script>
    {% endfor %}
</body>
</html>
