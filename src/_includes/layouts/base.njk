<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍕</text></svg>">
    <title>{{ title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    {# ---- Theme: 4 text styles (Display/Heading/Body/Caption), driven by
           src/_data/theme.json, editable in the CMS Design panel ---- #}
    {% for s in [theme.styles.display, theme.styles.heading, theme.styles.body, theme.styles.caption] %}{% if s.fontQuery %}<link href="https://fonts.googleapis.com/css2?family={{ s.fontQuery }}&display=swap" rel="stylesheet">
    {% endif %}{% endfor %}
    {% for cf in theme.customFonts %}<style>@font-face { font-family: "{{ cf.name }}"; src: url("/{{ cf.file }}") format("{{ cf.format }}"); font-display: swap; }</style>
    {% endfor %}
    <style>
      :root {
        --font-display: "{{ theme.styles.display.font }}";
        --font-heading: "{{ theme.styles.heading.font }}";
        --font-body: "{{ theme.styles.body.font }}";
        --font-caption: "{{ theme.styles.caption.font }}";
        --size-display: {{ theme.styles.display.size }}rem;
        --size-heading: {{ theme.styles.heading.size }}rem;
        --size-body: {{ theme.styles.body.size }}rem;
        --size-caption: {{ theme.styles.caption.size }}rem;
        --type-shrink: 1;
        --color-bg: {{ theme.colors.bg }};
        --color-text: {{ theme.colors.text }};
        --color-accent: {{ theme.colors.accent }};
      }
    </style>
    <link rel="stylesheet" href="main.css">
    <link rel="stylesheet" href="size-small.css">
    <link rel="stylesheet" href="size-large.css">
    {% for href in pageStyles %}<link rel="stylesheet" href="{{ href }}">
    {% endfor %}
</head>
<body>
    <main>
        {% include "partials/header.njk" %}
{{ content | safe }}
        {% include "partials/footer.njk" %}
    </main>

    <script src="dotcursor.js"></script>
    <script src="random-colors.js"></script>
    <script src="favicon.js"></script>
    <script src="header.js?v=2"></script>
    {% for src in pageScripts %}<script src="{{ src }}"></script>
    {% endfor %}
</body>
</html>
