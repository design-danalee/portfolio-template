---
layout: layouts/base.njk
permalink: about.html
title: About — Dana Lee
pageStyles:
  - about.css
pageScripts:
  - about.js
footer:
  left:  { href: "index.html#work", label: "Work",    id: "more-work" }
  right: { href: "contact.html",     label: "Contact", id: "contact" }
---
<section class="introduction">
    <section class="flex">
        <h1 class="hero-text">{{ about.hero }}</h1>
    </section>
</section>

{% for section in about.sections %}
<section class="about-section">
    <h2 class="t-heading">{{ section.heading }}</h2>
    <p>{{ section.body }}</p>
</section>
{% endfor %}

<section class="m-4 mt-64 mb-24">
    <h2 class="hero-text mb-10">{{ about.partner.heading }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for tile in about.partner.tiles %}
        <div class="partner-tile roundy aspect-square flex flex-col justify-between" style="background-color: #F5F5F5;">
            <h3 class="t-heading mb-3">{{ tile.title }}</h3>
            <p>{{ tile.body }}</p>
        </div>
        {% endfor %}
    </div>
</section>

<section class="m-4 mt-48 mb-4">
    <h2 class="hero-text mb-10">{{ about.dataPoints.heading }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="partner-tile roundy aspect-square flex items-center justify-center text-center" style="background-color: #F5F5F5;">
            <p id="random-fact" class="t-heading">{{ about.dataPoints.facts[0] }}</p>
        </div>
        <button id="roll-dice" type="button" class="partner-tile roundy aspect-square flex items-center justify-center text-center" style="background-color: #29292E; color: #ffffff; cursor: none;">
            <span class="t-heading">Roll the Dice</span>
        </button>
    </div>
    {# Facts are emitted here so the copy stays editable in the CMS; about.js reads them. #}
    <div id="facts-data" hidden>
        {% for fact in about.dataPoints.facts %}<span data-fact="{{ fact }}"></span>{% endfor %}
    </div>
</section>
