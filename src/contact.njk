---
layout: layouts/base.njk
permalink: contact.html
title: Contact
pageStyles:
  - contact.css
pageScripts:
  - contact.js
footer:
  left:  { href: "index.html#work", label: "Work",  id: "more-work" }
  right: { href: "about.html",       label: "About", id: "about" }
---
<section class="introduction">
    <section class="flex">
        <h1 class="hero-text">{{ contact.hero }}</h1>
    </section>
</section>

<section class="contact-section">
    <!-- Success / error messages -->
    <div id="form-status" class="mb-6 hidden rounded-2xl p-4 text-center t-body"></div>

    <form action="contact.php" method="POST" class="contact-form space-y-8" novalidate>
        {% for field in contact.fields %}
        <div>
            <label for="{{ field.id }}">{{ field.label }}</label>
            {% if field.type == "select" %}
            <div class="select-wrap">
                <select id="{{ field.id }}" name="{{ field.id }}"{% if field.required %} required{% endif %}>
                    <option value="" disabled selected>Select{% if not field.required %} (optional){% endif %}</option>
                    {% for opt in field.options %}<option>{{ opt }}</option>
                    {% endfor %}
                </select>
            </div>
            {% elif field.type == "textarea" %}
            <textarea id="{{ field.id }}" name="{{ field.id }}"{% if field.required %} required{% endif %}></textarea>
            {% else %}
            <input type="{{ field.type }}" id="{{ field.id }}" name="{{ field.id }}"{% if field.required %} required{% endif %} />
            {% endif %}
            {% if field.required %}<p class="field-error" id="{{ field.id }}-error" hidden>Please fill in {{ field.label | lower }}.</p>{% endif %}
        </div>
        {% endfor %}
        <div>
            <button type="submit" class="submit-btn">
                <span>Send it</span>
                <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" aria-hidden="true"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path></svg>
            </button>
        </div>
    </form>
</section>
